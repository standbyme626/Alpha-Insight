OPENAI_API_KEY="your_api_key_here"
OPENAI_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
OPENAI_MODEL_NAME="qwen-plus-2025-07-28"
# Optional models:
# - qwen-turbo-2025-07-15
# - qwen-plus-2025-07-28
# - qwen-max-latest
TEMPERATURE=0.0
ENABLE_LOCAL_FALLBACK=false
# Access control mode: blacklist|allowlist
# - blacklist (default): all chats allowed unless in TELEGRAM_BLOCKED_CHAT_IDS
# - allowlist: only TELEGRAM_ALLOWED_CHAT_IDS can access
TELEGRAM_ACCESS_MODE=blacklist
# Comma-separated chat ids used when TELEGRAM_ACCESS_MODE=allowlist
TELEGRAM_ALLOWED_CHAT_IDS=
# Comma-separated denied chat ids used when TELEGRAM_ACCESS_MODE=blacklist
TELEGRAM_BLOCKED_CHAT_IDS=
